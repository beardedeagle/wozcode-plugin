{
  // Bundled defaults. User entries in ~/.woz/router-config.jsonc override
  // by id/label.

  // Routing preset Claude Code dials by default.
  "claudecode": {
    "preset": "/claudecode"
  },
  "providers": [
    {
      "id": "llamacpp",
      "baseUrl": "http://localhost:8080/v1/",
      "apiKey": "empty",
      "transports": {
        "openai": {}
      }
    },
    {
      "id": "openai",
      "backend": "openai-native",
      "baseUrl": "https://api.openai.com/v1/",
      "apiKey": "${OPENAI_API_KEY}",
      // Map Claude tier slugs to OpenAI models for subagent dispatch.
      "modelMappings": [
        { "model": "*haiku*", "target": "gpt-5.4-mini" },
        { "model": "*sonnet*", "target": "gpt-5.4" },
        { "model": "*opus*", "target": "gpt-5.5" }
      ],
      "claudecode": {
        "expose": true
      },
      "transports": {
        "openai": {
          "modelConfig": {
            "apiStyle": "responses"
          }
        }
      }
    },
    {
      // AWS Bedrock Mantle. Serves OpenAI-compatible endpoints at `/v1/` and
      // the native Anthropic Messages API at `/anthropic/`.
      "id": "bedrock-mantle",
      "backend": "bedrock-mantle",
      "baseUrl": "https://bedrock-mantle.${AWS_REGION}.api.aws/v1/",
      "awsRegion": "${AWS_REGION}",
      // "awsProfile": "default",
      "timeoutInMs": 120000,
      "transports": {
        "openai": {
          "modelConfig": {
            "defaultReasoningEffort": "none",
            "minMaxCompletionTokens": 16
          }
        },
        "anthropic": {
          "baseUrl": "https://bedrock-mantle.${AWS_REGION}.api.aws/anthropic/",
          // Strip `anthropic-beta` flags the gateway doesn't accept. Stripping
          // `context-management-2025-06-27` also requires removing the matching
          // `context_management` body field.
          "requestModifications": [
            {
              "headers": {
                "removeValues": {
                  "anthropic-beta": [
                    "prompt-caching-scope-2026-01-05",
                    "oauth-2025-04-20"
                    // "context-management-2025-06-27"
                  ]
                }
              },
              "body": {
                // "remove": ["context_management"]
              }
            }
          ]
        }
      }
    },
    {
      "id": "azure-foundry",
      "backend": "azure-foundry",
      "baseUrl": "https://${FOUNDRY_RESOURCE_NAME}.openai.azure.com/openai/v1/",
      "apiKey": "${FOUNDRY_PROJECT_API_KEY}",
      "timeoutInMs": 120000,
      // Map Claude tier slugs to Azure Foundry deployment names.
      "modelMappings": [
        { "model": "*haiku*", "target": "gpt-5.4-mini" },
        { "model": "*sonnet*", "target": "gpt-5.4" },
        { "model": "*opus*", "target": "gpt-5.5-1" }
      ],
      "claudecode": {
        "expose": true
      },
      "transports": {
        "openai": {
          "modelConfig": {
            "defaultReasoningEffort": "none",
            "minMaxCompletionTokens": 16
          },
          // Steer GPT-5.x toward the WozCode MCP search/edit tools instead of
          // Claude Code's Read/Glob/Grep.
          "requestModifications": [
            {
              "when": {
                "preset": ["/claudecode", "/claudecode-azure"]
              },
              "systemPrompt": {
                /* Steering bullets disabled - redundant with the MCP Search/Edit tool descriptions.
                "append": [
                  "\n\n- Batch all changes for a task into ONE mcp__plugin_woz_code__Edit call's edits[] array — not one Edit call per file. Ten edits in one call beats ten calls with one edit each.\n- Search up front, then apply edits together. Don't search-edit-search-edit.\n- Combine independent searches into one mcp__plugin_woz_code__Search call (multiple file_glob_patterns or alternation in content_regex) instead of issuing them one at a time.\n- The Edit tool's \"smallest edit\" guidance is about each edit's payload size (don't regenerate untouched lines), not about the scope of work for the task. Do everything the prompt asks for in your batched Edit call."
                ] */
              }
            }
          ]
        }
      }
    },
    {
      // ChatGPT subscription via Codex CLI OAuth. Reuses tokens stored at
      // `~/.codex/auth.json` by `codex login`.
      "id": "chatgpt",
      "backend": "chatgpt-oauth",
      "baseUrl": "https://chatgpt.com/backend-api/codex/",
      "timeoutInMs": 120000,
      // Map Claude tier slugs to gateway-accepted model slugs.
      "modelMappings": [
        { "model": "*haiku*", "target": "gpt-5.4-mini" },
        { "model": "*sonnet*", "target": "gpt-5.4" },
        { "model": "*opus*", "target": "gpt-5.5" }
      ],
      "claudecode": {
        "expose": true
      },
      "transports": {
        "openai": {
          "modelConfig": {
            "apiStyle": "responses"
          },
          // Codex CLI fingerprint: system-prompt prefix, User-Agent, cookie
          // jar, and body-field strips required by the ChatGPT-auth gateway.
          "requestModifications": [
            {
              "when": {
                "preset": ["/claudecode", "/claudecode-chatgpt"]
              },
              "systemPrompt": {
                "prepend": ["${CODEX_CLI_SYSTEM_PROMPT_PREFIX}"]
              },
              "cookieJar": "cloudflare",
              "headers": {
                "add": {
                  "user-agent": "codex_cli_rs/0.32.0",
                  "originator": "codex_cli_rs"
                },
                // Strip headers that would tell the gateway this isn't Codex CLI.
                "remove": ["anthropic-*", "x-app", "x-claude-code-session-id", "x-stainless-*"]
              },
              "body": {
                "remove": [
                  "max_tokens",
                  "max_completion_tokens",
                  "max_output_tokens",
                  "metadata",
                  "prompt_cache_retention",
                  "temperature",
                  "top_p"
                ]
              }
            }
          ]
        }
      }
    },
    {
      // Native Anthropic API. Targeted by `/claudecode` and `/anthropic`
      // presets, both of which forward inbound auth headers.
      "id": "anthropic",
      "baseUrl": "https://api.anthropic.com",
      "transports": {
        "anthropic": {}
      }
    },
    {
      // Cursor: pricing-only entry for cost lookups on Cursor transcripts.
      "id": "cursor",
      "baseUrl": "https://api.cursor.com/v1/",
      "transports": {
        "openai": {}
      }
    }
  ],
  // Catalog of canonical models. Bindings reference these via `model` to
  // inherit shared properties (driver, pricing, request modifications).
  // Pricing is auto-injected from `src/router/router-config-pricing.ts` when
  // not set inline.
  "models": [
    { "id": "moonshotai:kimi-k2.6", "driver": "moonshotai" },
    { "id": "moonshotai:kimi-k2.5", "driver": "moonshotai" },
    { "id": "anthropic:claude-opus-4-8" },
    { "id": "anthropic:claude-opus-4-7" },
    { "id": "anthropic:claude-opus-4-6" },
    { "id": "anthropic:claude-opus-4-5" },
    { "id": "anthropic:claude-opus-4-0" },
    { "id": "anthropic:claude-sonnet-4-6" },
    { "id": "anthropic:claude-sonnet-4-5" },
    { "id": "anthropic:claude-sonnet-4-0" },
    { "id": "anthropic:claude-haiku-4-5" },
    { "id": "anthropic:claude-haiku-3-5" },
    { "id": "cursor:composer-2-fast" },
    { "id": "cursor:composer-2" },
    { "id": "cursor:composer-1.5" },
    { "id": "openai:gpt-5-mini" },
    { "id": "openai:gpt-5-nano" },
    { "id": "openai:gpt-5" },
    { "id": "openai:gpt-5.5" },
    { "id": "openai:gpt-5.4" },
    { "id": "openai:gpt-5.4-mini" },
    { "id": "openai:gpt-5.4-nano" },
    { "id": "openai:gpt-5.3-codex" }
  ],
  "bindings": [
    {
      "label": "GPT 5.5 (OpenAI)",
      "provider": "openai",
      "providerModel": "gpt-5.5-2026-04-23",
      "model": "openai:gpt-5.5"
    },
    {
      // ChatGPT subscription via Codex CLI OAuth. Valid model slugs come from
      // Codex CLI's catalog: gpt-5.5, gpt-5.4, gpt-5.4-mini.
      "label": "GPT 5.5 (ChatGPT)",
      "provider": "chatgpt",
      "providerModel": "gpt-5.5",
      "model": "openai:gpt-5.5",
      "transport": "openai",
      "config": {
        "apiStyle": "responses"
      }
    },
    {
      "label": "GPT 5.4 (ChatGPT)",
      "provider": "chatgpt",
      "providerModel": "gpt-5.4",
      "model": "openai:gpt-5.4",
      "transport": "openai",
      "config": {
        "apiStyle": "responses"
      }
    },
    {
      "label": "GPT 5.4 mini (ChatGPT)",
      "provider": "chatgpt",
      "providerModel": "gpt-5.4-mini",
      "model": "openai:gpt-5.4-mini",
      "transport": "openai",
      "config": {
        "apiStyle": "responses"
      }
    },
    {
      "label": "GPT 5.5 (Azure)",
      "provider": "azure-foundry",
      "providerModel": "gpt-5.5-1",
      "model": "openai:gpt-5.5",
      "config": {
        "apiStyle": "responses"
      }
    },
    {
      "label": "gpt-oss",
      "provider": "llamacpp",
      "providerModel": "gpt-oss"
    },

    // ----- AWS Bedrock Mantle bindings -----
    {
      "label": "Opus 4.7 (Bedrock)",
      "provider": "bedrock-mantle",
      "transport": "anthropic",
      // Use `global.anthropic.claude-opus-4-7` for cross-region routing.
      "providerModel": "anthropic.claude-opus-4-7",
      "model": "anthropic:claude-opus-4-7"
    },
    {
      "label": "GPT-OSS 120B (Bedrock)",
      "provider": "bedrock-mantle",
      "providerModel": "openai.gpt-oss-120b",
      "transport": "openai",
      "config": {
        "apiStyle": "responses"
      }
    },
    {
      "label": "DeepSeek V3.2 (Bedrock)",
      "provider": "bedrock-mantle",
      "providerModel": "deepseek.v3.2",
      "transport": "openai",
      "config": {
        "apiStyle": "responses",
        "supportsPromptCacheConfig": false
      }
    },
    {
      "label": "Kimi K2.5 (Bedrock)",
      "provider": "bedrock-mantle",
      "providerModel": "moonshotai.kimi-k2.5",
      "model": "moonshotai:kimi-k2.5",
      "transport": "openai",
      "config": {
        // "apiStyle": "responses",
        "supportsPromptCacheConfig": false
      }
    },
    {
      "label": "MiniMax M2.1 (Bedrock)",
      "provider": "bedrock-mantle",
      "providerModel": "minimax.minimax-m2.1",
      "transport": "openai"
    },
    {
      "label": "GLM 4.7 Flash (Bedrock)",
      "provider": "bedrock-mantle",
      "providerModel": "zai.glm-4.7-flash",
      "transport": "openai"
    },
    {
      "label": "GLM 4.7 (Bedrock)",
      "provider": "bedrock-mantle",
      "providerModel": "zai.glm-4.7",
      "transport": "openai",
      "config": {
        "apiStyle": "responses"
      }
    },
    {
      "label": "GLM 4.6 (Bedrock)",
      "provider": "bedrock-mantle",
      "providerModel": "zai.glm-4.6",
      "transport": "openai"
    },
    {
      "label": "GPT 5.4 (Azure)",
      "provider": "azure-foundry",
      "providerModel": "gpt-5.4",
      "model": "openai:gpt-5.4",
      "config": {
        "apiStyle": "responses"
      }
    },
    {
      "label": "GPT 5.4 mini (Azure)",
      "provider": "azure-foundry",
      "providerModel": "gpt-5.4-mini",
      "model": "openai:gpt-5.4-mini"
    },
    {
      "label": "GPT 5.4 nano (Azure)",
      "provider": "azure-foundry",
      "providerModel": "gpt-5.4-nano",
      "model": "openai:gpt-5.4-nano"
    },
    {
      "label": "DeepSeek-V3.2 (Azure)",
      "provider": "azure-foundry",
      "providerModel": "DeepSeek-V3.2-Speciale",
      "config": {
        "supportsPromptCacheConfig": false
      }
    },
    {
      "label": "Kimi K2.6 (Azure)",
      "provider": "azure-foundry",
      "providerModel": "kimi-k2.6",
      "model": "moonshotai:kimi-k2.6",
      "config": {
        "supportsPromptCacheConfig": false
      }
    },
    {
      "label": "Kimi K2.5 (Azure)",
      "provider": "azure-foundry",
      "providerModel": "kimi-k2.5",
      "model": "moonshotai:kimi-k2.5",
      "config": {
        "supportsPromptCacheConfig": false
      }
    }
    // Native Anthropic models route via catalog id lookup on the `anthropic`
    // provider — no explicit binding needed for pricing.
  ],
  // Routing presets addressable as `/router-preset<path>/v1/...`. Each preset
  // bundles a default provider plus optional name mappings.
  "routingPresets": [
    {
      // Generic Anthropic passthrough for non-Claude-Code clients.
      "path": "/anthropic",
      "defaultProvider": "anthropic",
      "passThroughAuth": true
    },
    {
      // Claude Code home base. Forwards inbound auth to api.anthropic.com.
      "path": "/claudecode",
      "defaultProvider": "anthropic",
      "passThroughAuth": true,
      "modelMappings": [
        { "model": "opus", "target": "claude-opus-4-7" },
        { "model": "sonnet", "target": "claude-sonnet-4-6" },
        { "model": "haiku", "target": "claude-haiku-4-5" }
      ]
      // "requestModifications": [
      //   {
      //     // Strip the `claude-code-guide` subagent entry from the Agent tool
      //     // description so the model doesn't try to delegate to it.
      //     "tools": {
      //       "edit": [{ "tool": "Agent", "search": "- claude-code-guide:${*}\n" }]
      //     },
      //     // Strip the "report the issue at github.com/anthropics/claude-code"
      //     // hint from the system prompt; not actionable from the router side.
      //     "systemPrompt": {
      //       "edit": [
      //         {
      //           "search": "\n${*}- To give feedback,${*}\n",
      //           "replace": "\n"
      //         }
      //       ]
      //     }
      //   }
      // ]
    },
    {
      // Claude Code -> ChatGPT subscription via Codex CLI OAuth.
      "path": "/claudecode-chatgpt",
      "defaultProvider": "chatgpt"
    },
    {
      // Claude Code -> Azure Foundry. Inherits tier-slug mappings from the
      // azure-foundry provider.
      "path": "/claudecode-azure",
      "defaultProvider": "azure-foundry"
    },
    {
      // OpenAI direct for the Codex CLI. Same tool-stripping and prompt
      // rewrites as /codex-azure; only the upstream provider differs.
      "path": "/codex",
      "defaultProvider": "openai",
      "requestModifications": [
        {
          "tools": {
            "remove": ["apply_patch", "view_image"]
          }
        },
        {
          "systemPrompt": {
            /* Steering bullets disabled - redundant with the MCP Search/Edit tool descriptions; the load-bearing edit rewrites below stay active.
            "append": [
              "\n\n- Batch all changes for a task into ONE mcp__plugin_woz_code__Edit call's edits[] array — not one Edit call per file. Ten edits in one call beats ten calls with one edit each.\n- Search up front, then apply edits together. Don't search-edit-search-edit.\n- Combine independent searches into one mcp__plugin_woz_code__Search call (multiple file_glob_patterns or alternation in content_regex) instead of issuing them one at a time.\n- The Edit tool's \"smallest edit\" guidance is about each edit's payload size (don't regenerate untouched lines), not about the scope of work for the task. Do everything the prompt asks for in your batched Edit call."
            ], */
            "edit": [
              {
                "search": "- When you search for text or files, you reach first for `rg`${**}- You parallelize tool calls whenever you can, especially file reads such as `cat`, `rg`, `sed`, `ls`, `${*}\n",
                "replace": "- When you search for text, discover files, or read file contents, use mcp__plugin_woz_code__Search instead of shell commands such as `rg`, `grep`, `cat`, `sed`, or `ls`.\n- Parallelize independent tool calls when possible, but prefer one combined mcp__plugin_woz_code__Search call for related file discovery, grep-style searches, and reads.\n"
              },
              {
                "search": "- Use `apply_patch` for manual code edits.${**}- Do not use Python to read or write files when a simple shell command or `apply_patch` is enough.\n",
                "replace": "- Use mcp__plugin_woz_code__Edit for manual code edits, file creation, and search/replace changes. Batch all changes for a task into one Edit call's edits[] array.\n- Do not use `apply_patch`, `cat`, heredocs, Python scripts, or other shell write tricks to create or edit files when mcp__plugin_woz_code__Edit can do it.\n"
              },
              {
                "search": "## `apply_patch`\n${**}\nshell {\"command\":[\"apply_patch\",\"*** Begin Patch\\n*** Add File: hello.txt\\n+Hello, world!\\n*** End Patch\\n\"]}\n```"
              }
            ]
          }
        }
      ]
    },
    {
      // Azure Foundry for the Codex CLI. Steers Codex away from built-in
      // patch/image tools and shell file-inspection commands so WozCode's MCP
      // search/edit tooling wins.
      "path": "/codex-azure",
      "defaultProvider": "azure-foundry",
      "requestModifications": [
        {
          "tools": {
            "remove": ["apply_patch", "view_image"]
          }
        },
        {
          "systemPrompt": {
            /* Steering bullets disabled - redundant with the MCP Search/Edit tool descriptions; the load-bearing edit rewrites below stay active.
            "append": [
              "\n\n- Batch all changes for a task into ONE mcp__plugin_woz_code__Edit call's edits[] array — not one Edit call per file. Ten edits in one call beats ten calls with one edit each.\n- Search up front, then apply edits together. Don't search-edit-search-edit.\n- Combine independent searches into one mcp__plugin_woz_code__Search call (multiple file_glob_patterns or alternation in content_regex) instead of issuing them one at a time.\n- The Edit tool's \"smallest edit\" guidance is about each edit's payload size (don't regenerate untouched lines), not about the scope of work for the task. Do everything the prompt asks for in your batched Edit call."
            ], */
            "edit": [
              {
                "search": "- When you search for text or files, you reach first for `rg`${**}- You parallelize tool calls whenever you can, especially file reads such as `cat`, `rg`, `sed`, `ls`, `${*}\n",
                "replace": "- When you search for text, discover files, or read file contents, use mcp__plugin_woz_code__Search instead of shell commands such as `rg`, `grep`, `cat`, `sed`, or `ls`.\n- Parallelize independent tool calls when possible, but prefer one combined mcp__plugin_woz_code__Search call for related file discovery, grep-style searches, and reads.\n"
              },
              {
                "search": "- Use `apply_patch` for manual code edits.${**}- Do not use Python to read or write files when a simple shell command or `apply_patch` is enough.\n",
                "replace": "- Use mcp__plugin_woz_code__Edit for manual code edits, file creation, and search/replace changes. Batch all changes for a task into one Edit call's edits[] array.\n- Do not use `apply_patch`, `cat`, heredocs, Python scripts, or other shell write tricks to create or edit files when mcp__plugin_woz_code__Edit can do it.\n"
              },
              {
                "search": "## `apply_patch`\n${**}\nshell {\"command\":[\"apply_patch\",\"*** Begin Patch\\n*** Add File: hello.txt\\n+Hello, world!\\n*** End Patch\\n\"]}\n```"
              }
            ]
          }
        }
      ],
      "modelMappings": [
        // Codex CLI sends `gpt-5.5`; Foundry's deployment name is `gpt-5.5-1`.
        { "model": "gpt-5.5", "target": "gpt-5.5-1" }
      ]
    }
  ]
}
