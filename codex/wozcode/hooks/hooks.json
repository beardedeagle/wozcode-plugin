{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/codex-session-hook.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/codex-session-hook.js"
          }
        ]
      },
      {
        "matcher": "mcp__plugin_woz_code__Edit|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/codex-session-hook.js"
          }
        ]
      }
    ]
  }
}
